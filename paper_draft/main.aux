\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Cosine similarity between compound representations and component representations at layer 11. All compounds maintain high similarity ($>0.89$) with their head nouns, indicating that compound representations are modifications of existing component directions rather than new directions. Best per-row result in \textbf  {bold} when noteworthy.\relax }}{5}{table.caption.3}\protected@file@percent }
\newlabel{tab:cosine}{{2}{5}{Cosine similarity between compound representations and component representations at layer 11. All compounds maintain high similarity ($>0.89$) with their head nouns, indicating that compound representations are modifications of existing component directions rather than new directions. Best per-row result in \textbf {bold} when noteworthy.\relax }{table.caption.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces SAE feature decomposition at layer 11. ``Unique'' is the fraction of compound features not shared with either component alone. ``Head/Mod.\ Overlap'' is the fraction of compound features also active for the head/modifier in isolation. Idiomatic compounds activate substantially more unique features than transparent ones. Best (most extreme) values in \textbf  {bold}.\relax }}{5}{table.caption.4}\protected@file@percent }
\newlabel{tab:sae}{{3}{5}{SAE feature decomposition at layer 11. ``Unique'' is the fraction of compound features not shared with either component alone. ``Head/Mod.\ Overlap'' is the fraction of compound features also active for the head/modifier in isolation. Idiomatic compounds activate substantially more unique features than transparent ones. Best (most extreme) values in \textbf {bold}.\relax }{table.caption.4}{}}
